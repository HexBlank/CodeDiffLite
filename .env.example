# App metadata
CODEDIFF_APP_NAME=CodeDiff Lite

# Runtime network config
CODEDIFF_HOST=0.0.0.0
CODEDIFF_PORT=8088

# Security
CODEDIFF_SECRET_KEY=replace-with-a-long-random-secret

# Storage
# Relative paths are resolved from the repository root.
CODEDIFF_DB_PATH=snippets.db

# Optional emergency admin reset token.
# Leave empty in normal deployments.
# CODEDIFF_TEMP_ADMIN_RESET_TOKEN=
